<view class="home-page {{isDark ? 'theme-dark' : ''}}">
  <background-image />
  <view class="ambient-strip"></view>

  <scroll-view class="home-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 骨架屏：数据加载前展示，消除冷启动白屏空档 -->
    <view class="sk-wrap" wx:if="{{loading}}">
      <view class="sk-hero">
        <view class="sk-avatar sk-bone"></view>
        <view class="sk-hero-text">
          <view class="sk-greeting sk-bone"></view>
          <view class="sk-subtitle sk-bone"></view>
        </view>
      </view>

      <view class="sk-ribbon glass-card">
        <view class="sk-ribbon-item">
          <view class="sk-ribbon-num sk-bone"></view>
          <view class="sk-ribbon-label sk-bone"></view>
        </view>
        <view class="sk-ribbon-div"></view>
        <view class="sk-ribbon-item">
          <view class="sk-ribbon-num sk-bone"></view>
          <view class="sk-ribbon-label sk-bone"></view>
        </view>
        <view class="sk-ribbon-div"></view>
        <view class="sk-ribbon-item">
          <view class="sk-ribbon-num sk-bone"></view>
          <view class="sk-ribbon-label sk-bone"></view>
        </view>
      </view>

      <view class="sk-card-row">
        <view class="sk-card glass-card">
          <view class="sk-card-icon sk-bone"></view>
          <view class="sk-card-title sk-bone"></view>
          <view class="sk-card-desc sk-bone"></view>
          <view class="sk-card-metrics">
            <view class="sk-metric sk-bone"></view>
            <view class="sk-metric-div"></view>
            <view class="sk-metric sk-bone"></view>
          </view>
          <view class="sk-card-arrow sk-bone"></view>
        </view>
        <view class="sk-card glass-card">
          <view class="sk-card-icon sk-bone"></view>
          <view class="sk-card-title sk-bone"></view>
          <view class="sk-card-desc sk-bone"></view>
          <view class="sk-card-metrics">
            <view class="sk-metric sk-bone"></view>
            <view class="sk-metric-div"></view>
            <view class="sk-metric sk-bone"></view>
          </view>
          <view class="sk-card-arrow sk-bone"></view>
        </view>
      </view>

      <view class="sk-quick-row">
        <view class="sk-quick">
          <view class="sk-quick-icon sk-bone"></view>
          <view class="sk-quick-label sk-bone"></view>
        </view>
        <view class="sk-quick">
          <view class="sk-quick-icon sk-bone"></view>
          <view class="sk-quick-label sk-bone"></view>
        </view>
      </view>

      <view class="sk-history">
        <view class="sk-history-header">
          <view class="sk-history-title sk-bone"></view>
          <view class="sk-history-more sk-bone"></view>
        </view>
        <view class="sk-history-card glass-card">
          <view class="sk-history-left">
            <view class="sk-history-name sk-bone"></view>
            <view class="sk-history-meta sk-bone"></view>
          </view>
          <view class="sk-history-right">
            <view class="sk-history-bar sk-bone"></view>
            <view class="sk-history-count sk-bone"></view>
          </view>
        </view>
        <view class="sk-history-card glass-card">
          <view class="sk-history-left">
            <view class="sk-history-name sk-bone"></view>
            <view class="sk-history-meta sk-bone"></view>
          </view>
          <view class="sk-history-right">
            <view class="sk-history-bar sk-bone"></view>
            <view class="sk-history-count sk-bone"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 真实内容 -->
    <block wx:else>
    <view class="hero-copy">
      <view class="hero-avatar" bindtap="handleAvatarTap" hover-class="pressing">
        <image class="mini-avatar" src="{{userAvatar || '/images/kzg/default-avatar.svg'}}" mode="aspectFill"></image>
      </view>
      <view class="hero-left">
        <view class="greeting">{{userName}}</view>
        <view class="subtitle">{{subtitle}}</view>
      </view>
    </view>

    <view class="stat-ribbon">
      <view class="stat-item checkin-stat {{checkedInToday ? 'checked-in' : ''}}" bindtap="handleCheckinTap" hover-class="pressing">
        <view class="stat-number">{{summary.checkinStreak}}</view>
        <view class="stat-label">{{checkedInToday ? '已打卡' : '连续打卡'}}</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-number">{{summary.weeklyStudyTime}}</view>
        <view class="stat-label">学习时长</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-number">{{summary.dueReview}}</view>
        <view class="stat-label">待复习</view>
      </view>
    </view>

    <!-- 斩题复活通知 -->
    <view class="revive-badge glass-card" wx:if="{{reviveCount > 0}}" bindtap="goSlashManage" hover-class="pressing">
      <image class="revive-icon" src="/images/kzg/slash-red.svg" mode="aspectFit" style="width:32rpx;height:32rpx;"></image>
      <view class="revive-text">已复活 {{reviveCount}} 个知识点，点击查看 →</view>
    </view>

    <view class="primary-row">
      <view
        wx:for="{{primaryCards}}"
        wx:key="id"
        class="glass-card main-card {{item.tone}}-card"
        data-id="{{item.id}}"
        bindtap="handlePrimaryTap"
        hover-class="pressing"
      >
        <view class="card-icon-area">
          <view class="icon-orbit {{item.tone}}-orbit">
            <image class="card-icon" src="{{item.icon}}" mode="aspectFit"></image>
          </view>
        </view>
        <view class="card-title">{{item.title}}</view>
        <view class="card-desc">{{item.desc}}</view>
        <view class="card-metrics {{item.tone}}-text">
          <view class="metric-item">
            <view class="metric-value">{{item.metricValue}}</view>
            <view class="metric-label-small">{{item.metricLabel}}</view>
          </view>
          <view class="metric-divider"></view>
          <view class="metric-item">
            <view class="metric-value">{{item.subMetricValue}}</view>
            <view class="metric-label-small">{{item.subMetricLabel}}</view>
          </view>
        </view>
        <view class="card-arrow">
          <image class="arrow-icon" src="/images/kzg/chevron-blue.svg" mode="aspectFit"></image>
        </view>
      </view>
    </view>

    <view class="quick-grid">
      <button
        wx:for="{{quickActions}}"
        wx:key="id"
        class="quick-action glass-button"
        data-id="{{item.id}}"
        bindtap="handleQuickAction"
        hover-class="pressing"
      >
        <view class="quick-icon-wrap">
          <image class="quick-icon" src="{{item.icon}}" mode="aspectFit"></image>
        </view>
        <view class="quick-label">{{item.label}}</view>
      </button>
    </view>

    <!-- 历史记录 -->
    <view class="history-section">
      <view class="section-header">
        <view class="section-title">历史记录</view>
        <view class="section-more" bindtap="handleHistoryMore">查看全部 ›</view>
      </view>
      <view class="history-list" wx:if="{{historyBanks.length > 0}}">
        <view
          wx:for="{{historyBanks}}"
          wx:key="id"
          class="history-card glass-card"
          data-id="{{item.id}}"
          bindtap="handleHistoryTap"
          hover-class="pressing"
        >
          <view class="history-info">
            <view class="history-name">{{item.name}}</view>
            <view class="history-meta">
              <text class="history-subject {{item.subject}}">{{item.subjectName}}</text>
              <text class="history-time">{{item.lastTime}}</text>
            </view>
          </view>
          <view class="history-right">
            <view class="history-progress-bar">
              <view class="history-progress-fill {{item.subject}}" style="width: {{item.progress}}%"></view>
            </view>
            <view class="history-count">已练{{item.doneCount}}题</view>
          </view>
        </view>
      </view>
      <view class="history-empty glass-card" wx:else bindtap="handleHistoryTap" hover-class="pressing">
        <image class="history-empty-icon" src="/images/kzg/pen-blue.svg" mode="aspectFit" style="width:28rpx;height:28rpx;"></image>
        <view class="history-empty-text">还没有练习记录，去题库开始刷题吧</view>
      </view>
    </view>
    </block>

  </scroll-view>

  <view class="bottom-dock">
    <view class="dock-glass-blur"></view>
    <view class="dock-glass-fill"></view>
    <view class="dock-glass-shine"></view>
    <view class="dock-content">
      <button
        wx:for="{{dockItems}}"
        wx:key="id"
        class="dock-item {{item.active ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="handleDockTap"
        hover-class="dock-pressing"
      >
        <view class="dock-icon-wrap">
          <image class="dock-icon" src="{{item.icon}}" mode="aspectFit"></image>
        </view>
        <view class="dock-label">{{item.label}}</view>
      </button>
    </view>
  </view>

    <button class="floating-edit" bindtap="handleQuickAction" data-id="import" aria-label="导入题库" hover-class="fab-pressing">
      <view class="fab-glass-blur"></view>
      <view class="fab-glass-fill"></view>
      <view class="fab-glass-shine"></view>
      <view class="fab-content">
        <image class="floating-icon" src="/images/kzg/pen-blue.svg" mode="aspectFit"></image>
        <text class="floating-label">导入</text>
      </view>
    </button>

  <!-- 用户信息卡片弹窗 -->
  <view class="user-card-overlay {{showUserCard ? 'visible' : ''}}" bindtap="hideUserCard">
    <view class="user-card glass-card" catchtap="noop">
      <image class="user-card-avatar" src="{{userAvatar || '/images/kzg/default-avatar.svg'}}" mode="aspectFill"></image>
      <view class="user-card-nickname">{{nickname || '导题斩题小工具用户'}}</view>
      <view class="user-card-stats">
        <view class="user-card-stat">
          <view class="user-card-stat-num">{{summary.totalSolved}}</view>
          <view class="user-card-stat-label">累计刷题</view>
        </view>
        <view class="user-card-stat-divider"></view>
        <view class="user-card-stat">
          <view class="user-card-stat-num">{{summary.checkinStreak}}</view>
          <view class="user-card-stat-label">连续打卡</view>
        </view>
        <view class="user-card-stat-divider"></view>
        <view class="user-card-stat">
          <view class="user-card-stat-num">{{summary.weeklyStudyTime}}</view>
          <view class="user-card-stat-label">本周学习</view>
        </view>
      </view>
      <!-- 主题模式切换 — 液态玻璃胶囊 -->
      <view class="theme-switch-glass">
        <view class="theme-glass-blur"></view>
        <view class="theme-glass-fill"></view>
        <view class="theme-glass-shine"></view>
        <view class="user-card-theme-row">
          <view class="theme-option {{themeMode === 'light' ? 'theme-active' : ''}}" data-mode="light" bindtap="switchTheme" hover-class="pressing">
            <image class="theme-icon-svg" src="/images/kzg/sun-blue.svg" mode="aspectFit"></image>
            <text class="theme-label">白天</text>
          </view>
          <view class="theme-option {{themeMode === 'dark' ? 'theme-active' : ''}}" data-mode="dark" bindtap="switchTheme" hover-class="pressing">
            <image class="theme-icon-svg" src="/images/kzg/moon-blue.svg" mode="aspectFit"></image>
            <text class="theme-label">深夜</text>
          </view>
          <view class="theme-option {{themeMode === 'system' ? 'theme-active' : ''}}" data-mode="system" bindtap="switchTheme" hover-class="pressing">
            <image class="theme-icon-svg" src="/images/kzg/auto-blue.svg" mode="aspectFit"></image>
            <text class="theme-label">跟随系统</text>
          </view>
        </view>
      </view>
      <view class="user-card-action" bindtap="goToMine" hover-class="pressing">编辑资料</view>
    </view>
  </view>
</view>
