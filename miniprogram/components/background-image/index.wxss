.bg-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
  opacity: 0.70;
  pointer-events: none;
}

.bg-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
  pointer-events: none;
}

/* 亮色遮罩 */
.bg-overlay-light {
  background: rgba(255, 255, 255, 0.15);
}

/* 深色遮罩 */
.bg-overlay-dark {
  background: rgba(0, 0, 0, 0.20);
}

