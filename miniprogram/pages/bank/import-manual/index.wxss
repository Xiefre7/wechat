/* 手动录入页 — 百词斩风格 */
page {
  width: 100%;
  min-height: 100vh;
  background: #F4F7FC;
  color: #1E2A3A;
  overflow-x: hidden;
}

button {
  padding: 0;
  margin: 0;
  text-align: left;
  line-height: normal;
  border-radius: 0;
  background: transparent;
  color: inherit;
}

button::after {
  border: 0;
}

.ambient-strip {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 240rpx;
  pointer-events: none;
  background:
    radial-gradient(ellipse 240rpx 160rpx at 50% 0%, rgba(74, 143, 234, 0.05), transparent 70%);
  filter: blur(12rpx);
}

.manual-page {
  position: relative;
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 8rpx) 0 0;
  overflow: hidden;
}

.manual-scroll {
  position: relative;
  z-index: 2;
  height: calc(100vh - env(safe-area-inset-top) - 8rpx);
  padding: 0 24rpx;
}

.page-header {
  padding: 20rpx 4rpx 12rpx;
}

.page-title {
  font-size: 44rpx;
  line-height: 1.18;
  font-weight: 850;
  color: #1A2538;
}

.page-desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: #5E718D;
}

/* ─── 玻璃基类 ─── */
.glass-card,
.glass-button {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  background: rgba(255, 255, 255, 0.42);
  -webkit-backdrop-filter: blur(34rpx);
  backdrop-filter: blur(34rpx);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78),
    0 14rpx 48rpx rgba(74, 143, 234, 0.08);
}

.glass-input {
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.42);
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78),
    0 2rpx 8rpx rgba(74, 143, 234, 0.04);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

/* ─── 表单卡片 ─── */
.form-card {
  padding: 28rpx 24rpx;
  border-radius: 32rpx;
  border-style: solid;
  border-color: #E6EAF2;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 26rpx;
  font-weight: 800;
  color: #1E2A3A;
  margin-bottom: 12rpx;
}

.required {
  color: #FF3B30;
}

.optional {
  font-weight: 400;
  color: #95A6BD;
  font-size: 22rpx;
}

/* ─── 题型选择 ─── */
.type-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.type-item {
  padding: 10rpx 22rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #5E718D;
  background: #F0F4FA;
  border: 1rpx solid #E6EAF2;
  transition: all 180ms ease;
}

.type-item.active {
  color: #4A8FEA;
  background: #EDF4FE;
  border-color: #A8CDF8;
}

/* ─── 文本框 ─── */
.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 18rpx;
  font-size: 26rpx;
  line-height: 1.65;
  color: #1E2A3A;
  box-sizing: border-box;
}

.form-textarea::placeholder {
  color: #95A6BD;
}

.form-input {
  width: 100%;
  height: 72rpx;
  padding: 0 18rpx;
  font-size: 28rpx;
  color: #1E2A3A;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #95A6BD;
}

/* ─── 选项区 ─── */
.options-area {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.option-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.option-key {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: #EDF4FE;
  font-size: 24rpx;
  font-weight: 800;
  color: #4A8FEA;
}

.option-input {
  flex: 1;
  height: 64rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #1E2A3A;
}

.option-delete {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: #FEF2F2;
  font-size: 32rpx;
  color: #FF3B30;
}

.add-option {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #D5DDE8;
  font-size: 24rpx;
  color: #4A8FEA;
  font-weight: 700;
}

/* ─── 判断题选项 ─── */
.tf-options {
  display: flex;
  gap: 16rpx;
}

.tf-option {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #E6EAF2;
}

.tf-option.selected {
  border-color: #34D399;
  background: #F0FDF4;
}

.tf-key {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: #EDF4FE;
  font-size: 22rpx;
  font-weight: 800;
  color: #4A8FEA;
}

.tf-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #1E2A3A;
}

/* ─── 答案选择器 ─── */
.answer-selector {
  display: flex;
  gap: 10rpx;
}

.answer-item {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #5E718D;
  background: #F0F4FA;
  border: 2rpx solid #E6EAF2;
  transition: all 180ms ease;
}

.answer-item.selected {
  color: #ffffff;
  background: #4A8FEA;
  border-color: #4A8FEA;
  box-shadow: 0 8rpx 20rpx rgba(74, 143, 234, 0.22);
}

.answer-hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #95A6BD;
}

/* ─── 操作按钮 ─── */
.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 24rpx;
}

.save-add {
  border: 1rpx solid #E6EAF2;
  background: #F4F7FC;
}

.save-add .btn-label {
  color: #4A8FEA;
}

.save-done {
  border: none;
  background: #4A8FEA;
  box-shadow: 0 8rpx 20rpx rgba(74, 143, 234, 0.2);
}

.save-done .btn-label {
  color: #ffffff;
}

.btn-label {
  font-size: 28rpx;
  font-weight: 800;
}

.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 48rpx);
}

.pressing {
  opacity: 0.78;
  transform: scale(0.985);
  transition: transform 180ms ease, opacity 180ms ease;
}

/* ─── 图片相关 ─── */
.q-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.q-image-thumb {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #E6EAF2;
}

.thumb-img {
  width: 100%;
  height: 100%;
}

.q-image-delete {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 59, 48, 0.85);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 20rpx;
  line-height: 1;
}

.q-image-add {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: auto;
  min-height: auto;
  padding: 16rpx 28rpx;
  margin-top: 10rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #B0C4DE;
  font-size: 24rpx;
  color: #4A8FEA;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.55);
}

.q-image-add .add-image-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

/* ─── 选项图片 ─── */
.opt-image-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  padding-left: 54rpx;
}

.opt-image-add-btn {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  color: #4A8FEA;
  background: #EDF4FE;
  border-radius: 12rpx;
  font-weight: 600;
  flex-shrink: 0;
  width: auto;
  min-height: auto;
}

.opt-image-add-btn .add-image-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.opt-image-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  border: 2rpx solid #E6EAF2;
  flex-shrink: 0;
}

.opt-image-remove {
  font-size: 22rpx;
  color: #FF3B30;
  font-weight: 600;
  flex-shrink: 0;
}

/* ─── 深色模式（由 .theme-dark 类驱动） ─── */
.theme-dark .page-title,
  .theme-dark .form-label {
    color: #FFFFFF;
    font-weight: 900;
  }

  .theme-dark .tf-text,
  .theme-dark .btn-label {
    color: rgba(255,255,255,0.6);
  }

  .theme-dark .page-desc,
  .theme-dark .answer-hint,
  .theme-dark .optional {
    color: rgba(255,255,255,0.6);
  }

  .theme-dark .type-item,
  .theme-dark .answer-item,
  .theme-dark .option-input,
  .theme-dark .form-input,
  .theme-dark .form-textarea {
    color: rgba(255,255,255,0.6);
  }

  .theme-dark .glass-card,
  .theme-dark .glass-button,
  .theme-dark .glass-input,
  .theme-dark .type-item {
    background: rgba(30, 41, 59, 0.6);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .theme-dark .type-item.active {
    background: rgba(37, 99, 235, 0.15);
    border-color: rgba(59, 130, 246, 0.3);
    color: #60A5FA;
  }

  .theme-dark .answer-item.selected {
    color: #ffffff;
    background: #2563EB;
    border-color: #2563EB;
  }

  .theme-dark .option-key,
  .theme-dark .tf-key {
    background: rgba(37, 99, 235, 0.12);
    color: #60A5FA;
  }

  .theme-dark .option-delete {
    background: rgba(255, 59, 48, 0.12);
    color: #F87171;
  }

  .theme-dark .tf-option {
    border-color: rgba(255, 255, 255, 0.08);
  }

  .theme-dark .tf-option.selected {
    border-color: rgba(52, 211, 153, 0.25);
    background: rgba(52, 211, 153, 0.08);
  }

  .theme-dark .save-add {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .theme-dark .add-option {
    border-color: rgba(255, 255, 255, 0.08);
  }

  .theme-dark .q-image-thumb {
    border-color: rgba(255, 255, 255, 0.08);
  }

  .theme-dark .q-image-add {
    border-color: rgba(255, 255, 255, 0.15);
    color: #60A5FA;
    background: rgba(30, 41, 59, 0.6);
  }

  .theme-dark .opt-image-add-btn {
    background: rgba(37, 99, 235, 0.15);
    color: #60A5FA;
  }

  .theme-dark .opt-image-thumb {
    border-color: rgba(255, 255, 255, 0.08);
  }

  .theme-dark .opt-image-remove {
    color: #F87171;
  }

/* ─── 填空题分空输入 ─── */
.fill-blank-count-hint {
  font-size: 22rpx;
  font-weight: 500;
  color: #95A6BD;
  margin-left: 4rpx;
}

.fill-blank-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.fill-blank-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.fill-blank-num {
  flex-shrink: 0;
  width: 64rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #4A8FEA;
  background: #EDF4FE;
  border-radius: 10rpx;
  padding: 8rpx 0;
  border: 1rpx solid #A8CDF8;
}

.fill-blank-input {
  flex: 1;
}

.fill-blank-del {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  font-size: 24rpx;
  color: #FF3B30;
  background: rgba(255, 59, 48, 0.08);
}

.fill-blank-add {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 12rpx 0;
  margin-top: 4rpx;
  border-radius: 12rpx;
  border: 1rpx dashed #A8CDF8;
  background: rgba(74, 143, 234, 0.04);
}

.fill-blank-add-icon {
  font-size: 28rpx;
  font-weight: 700;
  color: #4A8FEA;
}

.fill-blank-add-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #4A8FEA;
}

.theme-dark .fill-blank-num {
  color: #60A5FA;
  background: rgba(37, 99, 235, 0.12);
  border-color: rgba(59, 130, 246, 0.3);
}

.theme-dark .fill-blank-del {
  color: #F87171;
  background: rgba(255, 59, 48, 0.12);
}

.theme-dark .fill-blank-add {
  border-color: rgba(59, 130, 246, 0.3);
  background: rgba(37, 99, 235, 0.08);
}

.theme-dark .fill-blank-add-icon,
.theme-dark .fill-blank-add-text {
  color: #60A5FA;
}
