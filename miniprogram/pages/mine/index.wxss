/* 我的 — iOS26 液态玻璃风格 */
page {
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
  background: #F4F7FC;
}

button {
  padding: 0;
  margin: 0;
  text-align: left;
  line-height: normal;
  border-radius: 0;
  background: transparent;
  color: inherit;
}

button::after {
  border: 0;
}

/* ─── 环境光 ─── */
.ambient-strip {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 360rpx;
  pointer-events: none;
  background:
    radial-gradient(ellipse 300rpx 180rpx at 20% 10%, rgba(59, 130, 246, 0.16), transparent 60%),
    radial-gradient(ellipse 240rpx 150rpx at 70% 5%, rgba(90, 200, 250, 0.10), transparent 60%),
    radial-gradient(ellipse 200rpx 140rpx at 50% 18%, rgba(124, 92, 252, 0.08), transparent 60%);
  filter: blur(4rpx);
}

/* ─── 页面容器 ─── */
.mine-page {
  position: relative;
  width: 100%;
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 8rpx) 24rpx calc(env(safe-area-inset-bottom) + 88rpx);
  color: #1E2A3A;
  overflow: hidden;
}

.mine-scroll {
  position: relative;
  z-index: 2;
  height: calc(100vh - env(safe-area-inset-top) - env(safe-area-inset-bottom) - 96rpx);
  padding-bottom: 16rpx;
}

/* ─── 玻璃卡片基类 ─── */
.glass-card {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.42);
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78),
    0 14rpx 48rpx rgba(74, 143, 234, 0.08);
  -webkit-backdrop-filter: blur(34rpx);
  backdrop-filter: blur(34rpx);
}

/* ─── 头像卡片 ─── */
.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 40rpx;
  margin-top: 24rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 64rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 28rpx rgba(74, 143, 234, 0.14);
  background: rgba(74, 143, 234, 0.06);
}

.nickname {
  margin-top: 24rpx;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 850;
  color: #1E2A3A;
}

/* ─── 统计卡片 ─── */
.stats-card {
  margin-top: 24rpx;
  padding: 28rpx 24rpx 32rpx;
}

.stats-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1E2A3A;
  margin-bottom: 28rpx;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
}

.stat-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  box-sizing: border-box;
}

.stat-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  margin-bottom: 14rpx;
}

.blue-bg  { background: rgba(59, 130, 246, 0.10); }
.teal-bg  { background: rgba(16, 191, 155, 0.10); }
.purple-bg { background: rgba(124, 92, 252, 0.10); }
.warm-bg  { background: rgba(255, 107, 74, 0.10); }

.stat-icon {
  width: 32rpx;
  height: 32rpx;
}

.stat-number {
  font-size: 38rpx;
  line-height: 1.1;
  font-weight: 850;
  color: #1E2A3A;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(30, 42, 58, 0.52);
}

/* ─── 问题反馈 ─── */
.feedback-card {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
}

.feedback-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.feedback-icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
}

.feedback-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.feedback-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1E2A3A;
}

.feedback-desc {
  font-size: 24rpx;
  color: rgba(30, 42, 58, 0.52);
}

.feedback-chevron {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
  opacity: 0.4;
}

/* ─── 底部导航 ─── */
.bottom-dock {
  position: fixed;
  z-index: 6;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  min-height: calc(env(safe-area-inset-bottom) + 72rpx);
  padding: 6rpx 40rpx calc(env(safe-area-inset-bottom) + 6rpx);
  background: rgba(255, 255, 255, 0.94);
  border-top: 1rpx solid rgba(74, 143, 234, 0.08);
  -webkit-backdrop-filter: blur(40rpx);
  backdrop-filter: blur(40rpx);
}

.dock-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 72rpx;
  min-height: 52rpx;
  border-radius: 16rpx;
  text-align: center;
  opacity: 0.52;
  transition: opacity 180ms ease;
}

.dock-item.active {
  opacity: 1;
}

.dock-icon {
  width: 32rpx;
  height: 32rpx;
}

.dock-label {
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 500;
  color: #1E2A3A;
  text-align: center;
}

.dock-item.active .dock-label {
  background: linear-gradient(135deg, #4A8FEA, #7C5CFC);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 700;
}

.dock-pressing {
  opacity: 0.78;
  transform: scale(0.985);
  transition: transform 180ms ease, opacity 180ms ease;
}

/* ─── 头像编辑 ─── */
.avatar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  text-align: center;
  line-height: normal;
  border-radius: 0;
  background: transparent;
  color: inherit;
}

.avatar-btn::after {
  border: 0;
}

.avatar-edit-hint {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: rgba(30, 42, 58, 0.38);
  text-align: center;
}

/* ─── 昵称编辑 ─── */
.nickname-wrap {
  margin-top: 24rpx;
  width: 100%;
  display: flex;
  justify-content: center;
}

.nickname-input {
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 850;
  color: #1E2A3A;
  text-align: center;
  background: transparent;
  border: none;
  outline: none;
  width: 80%;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  transition: background 180ms ease;
}

.nickname-input:focus {
  background: rgba(74, 143, 234, 0.06);
}

/* ─── 深色模式（由 .theme-dark 类驱动） ─── */
.theme-dark .mine-page,
  .theme-dark .nickname,
  .theme-dark .stats-title,
  .theme-dark .stat-number {
    color: #FFFFFF;
    font-weight: 900;
  }

  .theme-dark .stat-label {
    color: #1A2538;
  }

  .theme-dark .glass-card {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.14);
  }

  .theme-dark .avatar {
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.06);
  }

  .theme-dark .bottom-dock {
    background: rgba(12, 24, 48, 0.94);
    border-top-color: rgba(255, 255, 255, 0.06);
  }

  .theme-dark .dock-label {
    color: #1A2538;
  }

  .theme-dark .feedback-title {
    color: #FFFFFF;
    font-weight: 900;
  }

  .theme-dark .feedback-desc {
    color: #1A2538;
  }

  .theme-dark .avatar-edit-hint {
    color: #1A2538;
  }

  .theme-dark .nickname-input {
    color: #FFFFFF;
    font-weight: 900;
  }

  .theme-dark .nickname-input:focus {
    background: rgba(255, 255, 255, 0.06);
  }
