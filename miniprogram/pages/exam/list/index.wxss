/* 历届真题列表页 — iOS26 液态玻璃风格 */
page {
  width: 100%;
  min-height: 100vh;
  background: #F4F7FC;
  color: #1E2A3A;
  overflow-x: hidden;
}

button {
  padding: 0;
  margin: 0;
  text-align: left;
  line-height: normal;
  border-radius: 0;
  background: transparent;
  color: inherit;
}

button::after { border: 0; }

/* ─── 环境光 ─── */
.ambient-strip {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 260rpx;
  pointer-events: none;
  background: radial-gradient(ellipse 240rpx 160rpx at 50% 0%, rgba(74,143,234,0.05), transparent 70%);
  filter: blur(12rpx);
}

.exam-list-page {
  position: relative;
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 8rpx) 0 0;
  overflow: hidden;
}

.page-scroll {
  position: relative;
  z-index: 2;
  height: calc(100vh - env(safe-area-inset-top) - 8rpx);
  padding: 0 24rpx;
}

/* ─── 页面头 ─── */
.page-header {
  padding: 20rpx 4rpx 8rpx;
}

.page-title {
  font-size: 44rpx;
  line-height: 1.18;
  font-weight: 850;
  color: #1A2538;
}

.page-desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: #5E718D;
}

/* ─── 水平滚动 Tab 栏 ─── */
.tab-scroll {
  white-space: nowrap;
  margin: 20rpx 0 18rpx;
}

.tab-bar {
  display: inline-flex;
  gap: 12rpx;
}

.tab-item {
  display: inline-block;
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #5E718D;
  background: #FFFFFF;
  border: 1rpx solid #E6EAF2;
  transition: all 180ms ease;
  white-space: nowrap;
}

.tab-item.active {
  color: #4A8FEA;
  background: #EDF4FE;
  border-color: #A8CDF8;
}

/* ─── 玻璃基类 ─── */
.glass-card {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  background: rgba(255, 255, 255, 0.42);
  -webkit-backdrop-filter: blur(34rpx);
  backdrop-filter: blur(34rpx);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78),
    0 14rpx 48rpx rgba(74, 143, 234, 0.08);
}

/* ─── 真题卡片 ─── */
.exam-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.exam-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: 28rpx;
  padding: 24rpx;
  min-height: 100rpx;
  transition: all 200ms ease;
}

.exam-card-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.exam-icon-wrap {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.exam-icon-text {
  font-size: 30rpx;
  font-weight: 850;
}

.exam-info {
  flex: 1;
  min-width: 0;
}

.exam-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #1A2538;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.exam-meta {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #95A6BD;
}

.exam-subcategory {
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #5AC8FA;
  background: rgba(90,200,250,0.08);
}

.exam-arrow {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: #F0F4FA;
  flex-shrink: 0;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
}

/* ─── 空状态 ─── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 64rpx;
}

.empty-text {
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #95A6BD;
}

.empty-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #D5DDE8;
  text-align: center;
  line-height: 1.5;
}

/* ─── 安全区 ─── */
.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 48rpx);
}

.pressing {
  opacity: 0.78;
  transform: scale(0.985);
}

/* ─── 深色模式（由 .theme-dark 类驱动） ─── */
.theme-dark .page-title,
.theme-dark .exam-name { color: #FFFFFF; font-weight: 900; }

.theme-dark .page-desc,
.theme-dark .exam-meta { color: rgba(255,255,255,0.6); }

.theme-dark .glass-card,
.theme-dark .tab-item {
  background: rgba(30,41,59,0.6);
  border-color: rgba(255,255,255,0.08);
}

.theme-dark .tab-item.active {
  background: rgba(0,122,255,0.12);
  border-color: rgba(0,122,255,0.25);
  color: #5AC8FA;
}

.theme-dark .exam-arrow { background: rgba(255,255,255,0.06); }

.theme-dark .exam-subcategory {
  color: #5AC8FA;
  background: rgba(90,200,250,0.12);
}
