page {
  width: 100%;
  min-height: 100vh;
  background: #F4F7FC;
}

.feedback-page {
  padding: 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 48rpx);
}

.feedback-form {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.form-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 750;
  color: #1E2A3A;
}

.type-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-chip {
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #4A5B72;
  background: rgba(255, 255, 255, 0.42);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
  transition: all 180ms ease;
}

.type-chip:active {
  transform: scale(0.96);
}

.chip-active {
  color: #ffffff;
  background: #4A8FEA;
  border-color: #4A8FEA;
}

.feedback-textarea {
  width: 100%;
  min-height: 240rpx;
  box-sizing: border-box;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #1E2A3A;
  background: rgba(255, 255, 255, 0.42);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.placeholder {
  color: #95A6BD;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #95A6BD;
}

.contact-input {
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1E2A3A;
  background: rgba(255, 255, 255, 0.42);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 92rpx;
  border-radius: 46rpx;
  background: linear-gradient(135deg, #FF3B30, #FF3B30);
  font-size: 30rpx;
  font-weight: 800;
  color: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(255, 59, 48, 0.32);
  margin-top: 8rpx;
}

.submit-btn:active {
  opacity: 0.85;
}

/* ─── 深色模式（由 .theme-dark 类驱动） ─── */
.theme-dark .section-title {
    color: #FFFFFF;
    font-weight: 900;
  }

  .theme-dark .type-chip {
    color: rgba(255,255,255,0.6);
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .theme-dark .chip-active {
    color: #ffffff;
    background: #3B82F6;
    border-color: #3B82F6;
  }

  .theme-dark .feedback-textarea,
  .theme-dark .contact-input {
    color: rgba(255,255,255,0.6);
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .theme-dark .placeholder {
    color: rgba(255,255,255,0.6);
  }

  .theme-dark .char-count {
    color: rgba(255,255,255,0.6);
  }
