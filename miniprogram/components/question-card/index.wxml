<!-- 题型标签 -->
<view class="type-badge">{{typeLabel}}</view>

<!-- 题干 -->
<view class="stem-card glass-card">
  <view class="stem-text">{{question.content.stem}}</view>
  <view class="stem-images" wx:if="{{question.hasStemImages}}">
    <view wx:for="{{question.content.stemImages}}" wx:key="*this" class="img-card-stem">
      <image src="{{item}}" mode="aspectFit" class="img-inner"
        bindtap="onStemImageTap" data-url="{{item}}" />
      <view class="img-tap-hint">
        <text class="img-tap-text">点击预览</text>
      </view>
    </view>
  </view>
</view>

<!-- 选择题（单选/多选/判断） -->
<view class="options-area" wx:if="{{question.hasOptions}}">
  <view
    wx:for="{{options}}"
    wx:key="key"
    class="option-item glass-card {{item._cls}}"
    data-key="{{item.key}}"
    bindtap="onOptionTap"
    hover-class="{{disabled ? '' : 'option-pressing'}}"
  >
    <view class="option-key {{question.isMulti ? 'checkbox' : ''}}">
      <text>{{item.key}}</text>
    </view>
    <view class="option-text">{{item.text}}</view>
    <view wx:if="{{item.image}}" class="img-card-opt">
      <image src="{{item.image}}" mode="aspectFit" class="img-inner"
        bindtap="onOptionImageTap" data-url="{{item.image}}" />
      <view class="img-tap-hint">
        <text class="img-tap-text">预览</text>
      </view>
    </view>
    <view class="option-icon" wx:if="{{showIcons}}">
      <text wx:if="{{item._isCorrect}}">✓</text>
    </view>
  </view>
</view>
