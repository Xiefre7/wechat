/* 答题结果页 — iOS26 液态玻璃风格 */
page {
  width: 100%;
  min-height: 100vh;
  background: #F4F7FC;
  color: #1E2A3A;
  overflow-x: hidden;
}

button {
  padding: 0; margin: 0;
  text-align: left;
  line-height: normal;
  border-radius: 0;
  background: transparent;
  color: inherit;
}

button::after { border: 0; }

/* ─── 环境光 ─── */
.ambient-strip {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 360rpx;
  pointer-events: none;
  background:
    radial-gradient(ellipse 300rpx 180rpx at 30% 5%, rgba(52,199,89,0.1), transparent 55%),
    radial-gradient(ellipse 240rpx 150rpx at 70% 10%, rgba(74,143,234,0.08), transparent 55%);
  filter: blur(8rpx);
}

.result-page {
  position: relative;
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 8rpx) 0 0;
  overflow: hidden;
}

.result-scroll {
  position: relative;
  z-index: 2;
  height: calc(100vh - env(safe-area-inset-top) - 8rpx);
  padding: 0 24rpx;
}

/* ─── 玻璃基类 ─── */
.glass-card,
.glass-button {
  position: relative;
  box-sizing: border-box;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  background: rgba(255, 255, 255, 0.42);
  -webkit-backdrop-filter: blur(34rpx);
  backdrop-filter: blur(34rpx);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78),
    0 14rpx 48rpx rgba(74, 143, 234, 0.08);
}

/* ─── 完成消息 ─── */
.finish-hero {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.finish-icon {
  font-size: 72rpx;
  margin-bottom: 12rpx;
}

.finish-title {
  font-size: 40rpx;
  font-weight: 850;
  color: #1A2538;
}

.finish-bank {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5E718D;
}

.finish-kp {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #95A6BD;
}

/* ─── 正确率环形图 ─── */
.accuracy-card {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  padding: 48rpx;
  border-radius: 32rpx;
}

.ring-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-bg {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 240rpx;
  height: 240rpx;
  border-radius: 120rpx;
  background: #F0F4FA;
}

.ring-number {
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1;
}

.ring-label {
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
}

/* ─── 统计网格 ─── */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.stat-card {
  width: calc((100% - 16rpx) / 2);
  padding: 24rpx;
  border-radius: 24rpx;
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.1;
}

.correct-val { color: #34C759; }
.wrong-val { color: #FF3B30; }
.time-val { color: #4A8FEA; }
.avg-val { color: #5AC8FA; }

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #95A6BD;
}

/* ─── 操作按钮 ─── */
.action-group {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 24rpx;
}

.action-btn.primary {
  border: none;
  background: linear-gradient(135deg, #4A8FEA, #3B7AD8);
  box-shadow: 0 8rpx 24rpx rgba(74,143,234,0.22);
}

.action-btn.primary .action-label {
  color: #ffffff;
}

.action-btn.secondary {
  border-color: rgba(255,59,48,0.15);
  background: rgba(255,59,48,0.04);
}

.action-btn.secondary .action-label {
  color: #FF3B30;
}

.action-btn.outline {
  border: 1.5rpx solid #E6EAF2;
}

.action-btn.outline .action-label {
  color: #5E718D;
}

.action-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.action-label {
  font-size: 28rpx;
  font-weight: 800;
}

/* ─── 答题详情 ─── */
.detail-section {
  margin-top: 28rpx;
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-radius: 24rpx;
}

.detail-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #1E2A3A;
}

.detail-toggle {
  font-size: 22rpx;
  color: #4A8FEA;
  font-weight: 600;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 16rpx;
}

.detail-card {
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
}

.detail-correct {
  border-color: rgba(52,199,89,0.15);
}

.detail-wrong {
  border-color: rgba(255,59,48,0.15);
}

/* ─── 题目头部 ─── */
.detail-q-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.detail-q-num {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  font-size: 22rpx;
  font-weight: 800;
  background: #F0F4FA;
  color: #5E718D;
  flex-shrink: 0;
}

.q-correct { background: rgba(52,199,89,0.12); color: #34C759; }
.q-wrong { background: rgba(255,59,48,0.1); color: #FF3B30; }

.detail-q-type {
  font-size: 20rpx;
  color: #95A6BD;
  flex: 1;
}

.detail-q-result {
  font-size: 22rpx;
  font-weight: 700;
}

.r-correct { color: #34C759; }
.r-wrong { color: #FF3B30; }
.r-pending { color: #5AC8FA; }

.detail-q-time {
  font-size: 20rpx;
  color: #95A6BD;
}

/* ─── 题目内容 ─── */
.detail-q-stem {
  font-size: 26rpx;
  line-height: 1.6;
  color: #1E2A3A;
  white-space: pre-wrap;
  word-break: break-word;
}

.detail-q-info {
  margin-top: 10rpx;
}

.detail-opt {
  font-size: 24rpx;
  line-height: 1.55;
  color: #4A5B72;
  padding: 3rpx 0;
}

.detail-opt-key {
  font-weight: 800;
  color: #4A8FEA;
  margin-right: 6rpx;
}

/* ─── 答案对比 ─── */
.detail-q-answers {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #F4F7FC;
}

.detail-answer-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.detail-answer-row:last-child { margin-bottom: 0; }

.da-label {
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.wrong-label { color: #FF3B30; }
.correct-label { color: #34C759; }

.da-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #1E2A3A;
}

.wrong-value { text-decoration: line-through; }

/* ─── 解析 ─── */
.detail-q-expl {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #E6EAF2;
  font-size: 22rpx;
  line-height: 1.6;
  color: #5E718D;
}

.expl-label {
  font-weight: 700;
  color: #4A8FEA;
}

.expl-text {
  color: #4A5B72;
}

/* ─── 背题模式记忆率 ─── */
.memorize-ring {
  background: rgba(74,143,234,0.06);
}

.memorize-rate-num {
  color: #4A8FEA;
}

.memorize-rate-label {
  color: #4A8FEA;
}

/* 背题详情 - 正确选项高亮 */
.opt-correct {
  color: #34C759 !important;
  font-weight: 800;
}

/* ─── 安全区 ─── */
.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 56rpx);
}

.pressing {
  opacity: 0.78;
  transform: scale(0.985);
}

/* ─── 深色模式（由 .theme-dark 类驱动） ─── */
.theme-dark .finish-title,
  .theme-dark .detail-title { color: #FFFFFF; font-weight: 900; }

  .theme-dark .detail-q-stem,
  .theme-dark .da-value { color: rgba(255,255,255,0.6); }

  .theme-dark .finish-bank,
  .theme-dark .detail-q-type,
  .theme-dark .detail-q-time,
  .theme-dark .expl-text,
  .theme-dark .finish-kp { color: rgba(255,255,255,0.6); }

  .theme-dark .glass-card,
  .theme-dark .glass-button {
    background: rgba(30,41,59,0.6);
    border-color: rgba(255,255,255,0.08);
  }

  .theme-dark .ring-bg { background: rgba(255,255,255,0.05); }

  .theme-dark .stat-label { color: rgba(255,255,255,0.6); }

  .theme-dark .action-btn.outline { border-color: rgba(255,255,255,0.08); }
  .theme-dark .action-btn.outline .action-label { color: rgba(255,255,255,0.6); }

  .theme-dark .detail-q-num { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.6); }
  .theme-dark .detail-q-answers { background: rgba(255,255,255,0.03); }
  .theme-dark .detail-q-expl { border-top-color: rgba(255,255,255,0.06); }

  .theme-dark .detail-opt { color: rgba(255,255,255,0.6); }
