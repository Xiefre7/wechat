<view class="preview-page {{isDark ? 'theme-dark' : ''}}">
  <background-image opacity="0.60" />
  <view class="ambient-strip"></view>

  <scroll-view class="preview-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 头部信息 -->
    <view class="page-header">
      <view class="page-title">预览与修正</view>
      <view class="page-desc">
        已解析 <text class="highlight">{{questions.length}}</text> 道题目，确认无误后即可导入题库
      </view>
    </view>

    <!-- 统计卡片 -->
    <view class="stats-card glass-card">
      <view class="stats-row">
        <view class="stats-item">
          <view class="stats-val">{{questions.length}}</view>
          <view class="stats-lbl">题目总数</view>
        </view>
        <view class="stats-div"></view>
        <view class="stats-item">
          <view class="stats-val">{{bankName}}</view>
          <view class="stats-lbl">题库名称</view>
        </view>
        <view class="stats-div"></view>
        <view class="stats-item">
          <view class="stats-val">{{typeDistribution}}</view>
          <view class="stats-lbl">题型分布</view>
        </view>
      </view>
    </view>

    <!-- 题目列表 -->
    <view class="question-list">
      <view
        wx:for="{{questions}}"
        wx:for-index="qi"
        wx:key="_idx"
        class="question-card glass-card {{item._editing ? 'editing' : ''}}"
      >
        <view class="q-header">
          <view class="q-num">{{qi + 1}}</view>
          <view class="q-type">{{item._typeLabel}}</view>
          <!-- 置信度指示器 -->
          <view
            wx:if="{{item._detectionConfidence === 'low' || item._detectionConfidence === 'medium'}}"
            class="confidence-badge {{item._detectionConfidence}}"
            data-index="{{qi}}"
            bindtap="toggleEdit"
          >
            <text wx:if="{{item._detectionConfidence === 'low'}}" class="confidence-icon">!</text>
            <text wx:if="{{item._detectionConfidence === 'medium'}}" class="confidence-icon">i</text>
          </view>
          <view class="q-actions">
            <view class="q-action-btn" data-index="{{qi}}" bindtap="toggleEdit">
              {{item._editing ? '完成' : '编辑'}}
            </view>
            <view class="q-action-btn danger" data-index="{{qi}}" bindtap="removeQuestion">删除</view>
          </view>
        </view>

        <!-- 预览模式 -->
        <view class="q-body" wx:if="{{!item._editing}}">
          <view class="q-stem">{{item.stem}}</view>
          <view class="q-images" wx:if="{{item._stemImages.length > 0}}">
            <view wx:for="{{item._stemImages}}" wx:key="*this" wx:for-item="imgUrl" class="img-card-stem">
              <image src="{{imgUrl}}" mode="aspectFit" class="img-inner"
                bindtap="onPreviewImage" data-url="{{imgUrl}}" />
              <view class="img-tap-hint">
                <text class="img-tap-text">点击预览</text>
              </view>
            </view>
          </view>
          <!-- 检测提示：低/中置信度时显示 -->
          <view wx:if="{{item._detectionNote}}" class="detection-note {{item._detectionConfidence}}">
            {{item._detectionNote}}
          </view>
          <view class="q-opts" wx:if="{{item.options.length > 0}}">
            <view wx:for="{{item.options}}" wx:key="key" wx:for-item="opt" class="q-opt">
              <text class="q-opt-key">{{opt.key}}.</text>
              <text class="q-opt-text">{{opt.text}}</text>
              <view wx:if="{{opt._image}}" class="img-card-opt">
                <image src="{{opt._image}}" mode="aspectFit" class="img-inner"
                  bindtap="onPreviewImage" data-url="{{opt._image}}" />
                <view class="img-tap-hint">
                  <text class="img-tap-text">预览</text>
                </view>
              </view>
            </view>
          </view>
          <view class="q-meta">
            <view class="q-answer {{item.type === 'multi_choice' ? 'multi' : ''}}">
              答案：<text class="answer-val">{{item.answer}}</text>
            </view>
            <view class="q-expl" wx:if="{{item.explanation}}">
              解析：<text class="expl-val">{{item.explanation}}</text>
            </view>
            <view class="q-images" wx:if="{{item._explanationImages.length > 0}}">
              <view wx:for="{{item._explanationImages}}" wx:key="*this" wx:for-item="imgUrl" class="img-card-stem">
                <image src="{{imgUrl}}" mode="aspectFit" class="img-inner"
                  bindtap="onPreviewImage" data-url="{{imgUrl}}" />
                <view class="img-tap-hint">
                  <text class="img-tap-text">点击预览</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 编辑模式 -->
        <view class="q-body" wx:else>
          <view class="edit-group">
            <view class="edit-label">题型</view>
            <view class="type-inline">
              <view
                wx:for="{{questionTypes}}"
                wx:key="value"
                wx:for-item="qt"
                wx:for-index="qti"
                class="type-chip {{item.type === qt.value ? 'active' : ''}}"
                data-index="{{qi}}"
                data-value="{{qt.value}}"
                bindtap="onItemTypeChange"
              >{{qt.label}}</view>
            </view>
          </view>
          <view class="edit-group">
            <view class="edit-label">题干</view>
            <textarea
              class="edit-textarea glass-input"
              value="{{item.stem}}"
              data-index="{{qi}}"
              data-field="stem"
              bindinput="onItemFieldChange"
              auto-height
            ></textarea>
            <view class="q-images" wx:if="{{item._stemImages.length > 0}}">
              <view wx:for="{{item._stemImages}}" wx:key="*this" wx:for-item="imgUrl" class="q-image-thumb">
                <image src="{{imgUrl}}" mode="aspectFit" class="thumb-img" />
                <view class="q-image-delete" data-index="{{qi}}" data-img-url="{{imgUrl}}" catchtap="onRemoveStemImage">×</view>
              </view>
            </view>
            <view class="q-image-add glass-button" data-index="{{qi}}" bindtap="onChooseStemImage">
              <image src="/images/kzg/camera-alt.svg" class="add-image-icon" mode="aspectFit"></image>添加题干图片（最多3张）
            </view>
          </view>
          <view class="edit-group" wx:if="{{item.options.length > 0}}">
            <view class="edit-label">选项</view>
            <view class="edit-opts">
              <block wx:for="{{item.options}}" wx:key="key" wx:for-item="opt" wx:for-index="optIndex">
                <view class="edit-opt-row">
                  <view class="edit-opt-key">{{opt.key}}</view>
                  <input
                    class="edit-opt-input glass-input"
                    value="{{opt.text}}"
                    data-index="{{qi}}"
                    data-opt-index="{{optIndex}}"
                    bindinput="onItemOptionChange"
                  />
                  <view
                    class="opt-del-btn"
                    data-index="{{qi}}"
                    data-opt-index="{{optIndex}}"
                    bindtap="deleteOption"
                    wx:if="{{item.options.length > 2}}"
                  >×</view>
                </view>
                <view class="opt-image-row" wx:if="{{item.type === 'single_choice' || item.type === 'multi_choice' || item.type === 'true_false'}}">
                  <view class="opt-image-add-btn glass-button" data-index="{{qi}}" data-opt-index="{{optIndex}}" catchtap="onChooseOptionImage">
                    <image src="/images/kzg/camera-alt.svg" class="add-image-icon" mode="aspectFit"></image>{{opt._image ? '更换图片' : '添加图片'}}
                  </view>
                  <image wx:if="{{opt._image}}" src="{{opt._image}}" mode="aspectFit"
                    class="opt-image-thumb" bindtap="onPreviewImage" data-url="{{opt._image}}" />
                  <view wx:if="{{opt._image}}" class="opt-image-remove" data-index="{{qi}}" data-opt-index="{{optIndex}}" catchtap="onRemoveOptionImage">× 删除</view>
                </view>
              </block>
            </view>
            <view
              class="add-opt-btn glass-button"
              data-index="{{qi}}"
              bindtap="addOption"
              wx:if="{{item.options.length < 10 && (item.type === 'single_choice' || item.type === 'multi_choice')}}"
            >＋ 添加选项</view>
          </view>
          <!-- 答案：单选/多选用选项按钮 -->
          <view class="edit-group" wx:if="{{item.type === 'single_choice' || item.type === 'multi_choice'}}">
            <view class="edit-label">答案 <text class="opt-required">*</text></view>
            <view class="answer-opts">
              <view
                wx:for="{{item.options}}"
                wx:key="key"
                wx:for-item="opt"
                class="answer-opt {{opt._sel ? 'selected' : ''}}"
                data-q-idx="{{qi}}"
                data-opt-key="{{opt.key}}"
                catchtap="toggleOptionAnswer"
              >{{opt.key}}</view>
            </view>
            <view class="answer-hint" wx:if="{{item.type === 'multi_choice'}}">多选题请点击所有正确选项</view>
          </view>
          <!-- 答案：判断题用对/错按钮 -->
          <view class="edit-group" wx:elif="{{item.type === 'true_false'}}">
            <view class="edit-label">答案 <text class="opt-required">*</text></view>
            <view class="answer-opts">
              <view class="answer-opt{{item.answer === 'A' ? ' selected' : ''}}"
                data-q-idx="{{qi}}" data-opt-key="A" catchtap="toggleOptionAnswer">对</view>
              <view class="answer-opt{{item.answer === 'B' ? ' selected' : ''}}"
                data-q-idx="{{qi}}" data-opt-key="B" catchtap="toggleOptionAnswer">错</view>
            </view>
          </view>
          <!-- 答案：填空题用文本框 -->
          <view class="edit-group" wx:elif="{{item.type === 'fill_blank'}}">
            <view class="edit-label">答案 <text class="opt-required">*</text></view>
            <input
              class="edit-input glass-input"
              value="{{item.answer}}"
              placeholder="多个填空用 | 分隔"
              data-index="{{qi}}"
              data-field="answer"
              bindinput="onItemFieldChange"
            />
          </view>
          <!-- 答案：简答题用多行文本框 -->
          <view class="edit-group" wx:elif="{{item.type === 'short_answer'}}">
            <view class="edit-label">参考答案</view>
            <textarea
              class="edit-textarea glass-input"
              value="{{item.answer}}"
              placeholder="请输入参考答案..."
              data-index="{{qi}}"
              data-field="answer"
              bindinput="onItemFieldChange"
              maxlength="2000"
              auto-height
            ></textarea>
          </view>
          <view class="edit-group">
            <view class="edit-label">解析</view>
            <textarea
              class="edit-textarea glass-input"
              value="{{item.explanation}}"
              data-index="{{qi}}"
              data-field="explanation"
              bindinput="onItemFieldChange"
              auto-height
            ></textarea>
            <view class="q-images" wx:if="{{item._explanationImages.length > 0}}">
              <view wx:for="{{item._explanationImages}}" wx:key="*this" wx:for-item="imgUrl" class="q-image-thumb">
                <image src="{{imgUrl}}" mode="aspectFit" class="thumb-img" />
                <view class="q-image-delete" data-index="{{qi}}" data-img-url="{{imgUrl}}" catchtap="onRemoveExplanationImage">×</view>
              </view>
            </view>
            <view class="q-image-add glass-button" data-index="{{qi}}" bindtap="onChooseExplanationImage">
              <image src="/images/kzg/camera-alt.svg" class="add-image-icon" mode="aspectFit"></image>添加解析图片（最多3张）
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{questions.length === 0}}">
      <image class="empty-icon" src="/images/kzg/file-blue.svg" mode="aspectFit" style="width:64rpx;height:64rpx;"></image>
      <view class="empty-text">未解析到题目</view>
      <view class="empty-desc">请检查导入内容格式后重试</view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-bar" wx:if="{{questions.length > 0 || isExcelImport}}">
      <view class="import-progress">
        <view class="progress-text" wx:if="{{!isExcelImport}}">准备导入 {{questions.length}} 题到「{{bankName}}」</view>
        <view class="progress-text" wx:else>Excel 文件将在服务端解析后导入到「{{bankName}}」</view>
        <view class="import-tip" wx:if="{{importing}}">正在导入中，请勿离开页面...</view>
      </view>
      <button
        class="confirm-btn glass-card"
        bindtap="confirmImport"
        hover-class="pressing"
        disabled="{{importing}}"
      >
        <view class="confirm-label">{{importing ? '导入中...' : '确认导入'}}</view>
      </button>
      <button class="cancel-btn glass-button" bindtap="goBack" hover-class="pressing">
        <view class="cancel-label">返回修改</view>
      </button>
    </view>

    <view class="safe-bottom"></view>
  </scroll-view>
</view>
