.privacy-page {
  min-height: 100vh;
  position: relative;
}

.privacy-scroll {
  height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.privacy-card {
  padding: 40rpx 32rpx;
  border-radius: 28rpx;
  min-height: calc(100vh - 48rpx);
}

.privacy-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #102A56;
  text-align: center;
  margin-bottom: 12rpx;
}

.theme-dark .privacy-title {
  color: rgba(255, 255, 255, 0.9);
}

.privacy-update {
  font-size: 24rpx;
  color: #5E718D;
  text-align: center;
  margin-bottom: 40rpx;
}

.theme-dark .privacy-update {
  color: rgba(255, 255, 255, 0.5);
}

.privacy-section {
  margin-bottom: 32rpx;
}

.section-heading {
  font-size: 30rpx;
  font-weight: 600;
  color: #102A56;
  margin-bottom: 16rpx;
}

.theme-dark .section-heading {
  color: rgba(255, 255, 255, 0.85);
}

.section-text {
  font-size: 26rpx;
  line-height: 1.8;
  color: #5E718D;
  margin-bottom: 8rpx;
}

.theme-dark .section-text {
  color: rgba(255, 255, 255, 0.6);
}

.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 48rpx);
}
