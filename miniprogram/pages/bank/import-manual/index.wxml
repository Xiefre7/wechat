<view class="manual-page {{isDark ? 'theme-dark' : ''}}">
  <background-image opacity="0.60" />
  <view class="ambient-strip"></view>

  <scroll-view class="manual-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="page-header">
      <view class="page-title">{{isEditing ? '编辑题目' : '录入题目'}}</view>
      <view class="page-desc">逐题填写以下信息，完成后可继续添加下一题</view>
    </view>

    <view class="form-card glass-card">
      <!-- 题型选择 -->
      <view class="form-group">
        <view class="form-label">题型 <text class="required">*</text></view>
        <view class="type-selector">
          <view
            wx:for="{{questionTypes}}"
            wx:key="value"
            class="type-item {{form.type === item.value ? 'active' : ''}}"
            data-type="{{item.value}}"
            bindtap="selectType"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <!-- 题干 -->
      <view class="form-group">
        <view class="form-label">题干 <text class="required">*</text></view>
        <textarea
          class="form-textarea glass-input"
          placeholder="请输入题目内容"
          value="{{form.stem}}"
          bindinput="onFieldChange"
          data-field="stem"
          maxlength="2000"
          auto-height
        ></textarea>
        <view class="q-images" wx:if="{{form._stemImages.length > 0}}">
          <view wx:for="{{form._stemImages}}" wx:key="*this" wx:for-item="imgUrl" class="q-image-thumb">
            <image src="{{imgUrl}}" mode="aspectFill" class="thumb-img" bindtap="onPreviewImage" data-url="{{imgUrl}}" />
            <view class="q-image-delete" data-img-url="{{imgUrl}}" catchtap="onRemoveStemImage">×</view>
          </view>
        </view>
        <view class="q-image-add glass-button" bindtap="onChooseStemImage">
          <image src="/images/kzg/camera-alt.svg" class="add-image-icon" mode="aspectFit"></image>添加题干图片（最多3张）
        </view>
      </view>

      <!-- 选项（非简答题显示） -->
      <view class="form-group" wx:if="{{showOptions}}">
        <view class="form-label">选项 <text class="required">*</text></view>
        <view class="options-area">
          <block wx:for="{{form.options}}" wx:key="key">
            <view class="option-row">
              <view class="option-key">{{item.key}}</view>
              <input
                class="option-input glass-input"
                placeholder="选项{{item.key}}内容"
                value="{{item.text}}"
                bindinput="onOptionChange"
                data-index="{{index}}"
                maxlength="500"
              />
              <view
                class="option-delete"
                data-index="{{index}}"
                bindtap="deleteOption"
                wx:if="{{form.options.length > 2}}"
              >×</view>
            </view>
            <view class="opt-image-row" wx:if="{{form.type === 'single_choice' || form.type === 'multi_choice' || form.type === 'true_false'}}">
              <view class="opt-image-add-btn glass-button" data-opt-index="{{index}}" catchtap="onChooseOptionImage">
                <image src="/images/kzg/camera-alt.svg" class="add-image-icon" mode="aspectFit"></image>{{item._image ? '更换图片' : '添加图片'}}
              </view>
              <image wx:if="{{item._image}}" src="{{item._image}}" mode="aspectFill" class="opt-image-thumb" bindtap="onPreviewImage" data-url="{{item._image}}" />
              <view wx:if="{{item._image}}" class="opt-image-remove" data-opt-index="{{index}}" catchtap="onRemoveOptionImage">× 删除</view>
            </view>
          </block>
          <view
            class="add-option glass-button"
            bindtap="addOption"
            wx:if="{{form.options.length < 10}}"
          >
            ＋ 添加选项
          </view>
        </view>
      </view>

      <!-- 判断题选项 -->
      <view class="form-group" wx:if="{{form.type === 'true_false'}}">
        <view class="form-label">选项</view>
        <view class="tf-options">
          <view class="tf-option glass-button {{form.answer === '对' ? 'selected' : ''}}" bindtap="setTfAnswer" data-value="对">
            <view class="tf-key">A</view>
            <view class="tf-text">对 ✓</view>
          </view>
          <view class="tf-option glass-button {{form.answer === '错' ? 'selected' : ''}}" bindtap="setTfAnswer" data-value="错">
            <view class="tf-key">B</view>
            <view class="tf-text">错 ✗</view>
          </view>
        </view>
      </view>

      <!-- 答案 -->
      <view class="form-group" wx:if="{{form.type !== 'short_answer'}}">
        <view class="form-label">答案 <text class="required">*</text></view>
        <view wx:if="{{form.type === 'single_choice' || form.type === 'multi_choice'}}">
          <view class="answer-selector">
            <view
              wx:for="{{form.options}}"
              wx:key="key"
              class="answer-item {{selectedAnswers[item.key] ? 'selected' : ''}}"
              data-key="{{item.key}}"
              bindtap="toggleAnswer"
            >
              {{item.key}}
            </view>
          </view>
          <view class="answer-hint" wx:if="{{form.type === 'multi_choice'}}">多选题请点击所有正确选项</view>
        </view>
        <view wx:elif="{{form.type === 'true_false'}}">
          <view class="answer-selector">
            <view
              class="answer-item {{form.answer === '对' ? 'selected' : ''}}"
              data-value="对"
              bindtap="setAnswer"
            >对</view>
            <view
              class="answer-item {{form.answer === '错' ? 'selected' : ''}}"
              data-value="错"
              bindtap="setAnswer"
            >错</view>
          </view>
        </view>
        <input
          wx:if="{{form.type === 'fill_blank'}}"
          class="form-input glass-input"
          placeholder="请输入答案（多个填空用 | 分隔）"
          value="{{form.answer}}"
          bindinput="onFieldChange"
          data-field="answer"
          maxlength="500"
        />
      </view>

      <!-- 简答题答案 -->
      <view class="form-group" wx:if="{{form.type === 'short_answer'}}">
        <view class="form-label">参考答案 <text class="required">*</text></view>
        <textarea
          class="form-textarea glass-input"
          placeholder="请输入参考答案"
          value="{{form.answer}}"
          bindinput="onFieldChange"
          data-field="answer"
          maxlength="2000"
          auto-height
        ></textarea>
      </view>

      <!-- 解析 -->
      <view class="form-group">
        <view class="form-label">解析 <text class="optional">（选填）</text></view>
        <textarea
          class="form-textarea glass-input"
          placeholder="请输入题目解析"
          value="{{form.explanation}}"
          bindinput="onFieldChange"
          data-field="explanation"
          maxlength="2000"
          auto-height
        ></textarea>
        <view class="q-images" wx:if="{{form._explanationImages.length > 0}}">
          <view wx:for="{{form._explanationImages}}" wx:key="*this" wx:for-item="imgUrl" class="q-image-thumb">
            <image src="{{imgUrl}}" mode="aspectFill" class="thumb-img" bindtap="onPreviewImage" data-url="{{imgUrl}}" />
            <view class="q-image-delete" data-img-url="{{imgUrl}}" catchtap="onRemoveExplanationImage">×</view>
          </view>
        </view>
        <view class="q-image-add glass-button" bindtap="onChooseExplanationImage">
          <image src="/images/kzg/camera-alt.svg" class="add-image-icon" mode="aspectFit"></image>添加解析图片（最多3张）
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-row">
      <button class="action-btn save-add glass-card" bindtap="saveAndContinue" hover-class="pressing">
        <view class="btn-label">保存并继续添加</view>
      </button>
      <button class="action-btn save-done glass-card" bindtap="saveAndFinish" hover-class="pressing">
        <view class="btn-label">保存并完成</view>
      </button>
    </view>

    <view class="safe-bottom"></view>
  </scroll-view>
</view>
