/* 占位页 — 百词斩风格 */
page {
  min-height: 100vh;
  background: #F4F7FC;
}

button {
  padding: 0;
  margin: 0;
  background: transparent;
  line-height: normal;
  text-align: center;
}

button::after {
  border: 0;
}

.placeholder-page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 64rpx) 32rpx calc(env(safe-area-inset-bottom) + 64rpx);
  color: #1E2A3A;
}

.placeholder-panel {
  padding: 44rpx 36rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.42);
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78),
    0 14rpx 48rpx rgba(74, 143, 234, 0.08);
  -webkit-backdrop-filter: blur(34rpx);
  backdrop-filter: blur(34rpx);
}

.eyebrow {
  font-size: 24rpx;
  font-weight: 800;
  color: #FF6B4A;
}

.title {
  margin-top: 16rpx;
  font-size: 44rpx;
  line-height: 1.18;
  font-weight: 850;
  color: #1A2538;
}

.desc {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.55;
  color: #5E718D;
}

.back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  margin-top: 34rpx;
  border-radius: 24rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  background: #4A8FEA;
  box-shadow: 0 8rpx 20rpx rgba(37, 99, 235, 0.2);
}

/* ─── 深色模式（由 .theme-dark 类驱动） ─── */
.theme-dark .placeholder-page,
  .theme-dark .title {
    color: #FFFFFF;
    font-weight: 900;
  }

  .theme-dark .placeholder-panel {
    background: rgba(30, 41, 59, 0.6);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  }

  .theme-dark .desc {
    color: #1A2538;
  }
